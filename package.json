{
  "name": "compi",
  "version": "0.5.0",
  "description": "A terminal creature collection game — catch digital beings as you work",
  "main": "scripts/cli.js",
  "bin": {
    "compi": "scripts/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:all": "tsc && npm run bundle",
    "bundle": "esbuild src/mcp-server.ts src/mcp-server-cursor.ts src/cli.ts --bundle --platform=node --format=cjs --target=node20 --outdir=scripts --allow-overwrite",
    "test": "jest",
    "test:watch": "jest --watch",
    "dev": "tsc --watch",
    "sim": "ts-node src/simulation/cli.ts all",
    "sim:bugs": "ts-node src/simulation/cli.ts bugs",
    "sim:balance": "ts-node src/simulation/cli.ts balance",
    "sim:smoke": "ts-node src/simulation/cli.ts smoke",
    "sim:ux": "ts-node src/simulation/cli.ts ux"
  },
  "keywords": [
    "cli",
    "game",
    "terminal",
    "claude-code",
    "plugin"
  ],
  "license": "MIT",
  "files": [
    "scripts/",
    "skills/",
    "cursor-skills/",
    "hooks/",
    ".claude-plugin/",
    ".cursor-plugin/",
    "README.md"
  ],
  "prepublishOnly": "npm run build:all",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "string-width": "^4.2.3"
  }
}
