{
  "name": "compi",
  "version": "0.1.0",
  "description": "A terminal creature collection game — catch digital beings as you work",
  "main": "dist/index.js",
  "bin": {
    "compi": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp src/mcp-app.html dist/mcp-app.html",
    "test": "jest",
    "test:watch": "jest --watch",
    "dev": "tsc --watch",
    "serve:cursor": "node dist/mcp-http-server.js"
  },
  "keywords": [
    "cli",
    "game",
    "terminal",
    "claude-code",
    "plugin"
  ],
  "license": "MIT",
  "files": [
    "dist/",
    "scripts/",
    "skills/",
    "cursor-skills/",
    "hooks/",
    ".claude-plugin/",
    ".cursor-plugin/",
    "README.md"
  ],
  "prepublishOnly": "npm run build",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "string-width": "^4.2.3"
  }
}
